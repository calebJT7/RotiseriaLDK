<MudNavMenu>
    <MudText Typo="Typo.h6" Class="px-4 py-3">ROTISERIA LDK</MudText>
    <MudDivider Class="mb-2" />

    @* Link a la toma de pedidos *@
    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.ShoppingCart">
        Tomar Pedido
    </MudNavLink>

    @* Link a la gestión de clientes y deudores *@
    <MudNavLink Href="/customers" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.People">
        Clientes y Fiados
    </MudNavLink>

    @* Link al historial de ventas *@
    <MudNavLink Href="/orders-history" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.ReceiptLong">
        Historial de Ventas
    </MudNavLink>

    @* Link al Dashboard de finanzas (Día 27) *@
    <MudNavLink Href="/dashboard" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Analytics"
                Color="Color.Info">
        Finanzas y Stock
    </MudNavLink>
</MudNavMenu>
<MudNavLink Href="/products-admin" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Fastfood">
    Gestión de Menú
</MudNavLink>
@code {
    // Aquí no hace falta lógica de Toggle porque MudBlazor lo maneja solo en el MainLayout
}
