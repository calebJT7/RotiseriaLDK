@page "/products-admin"
@using RotiseriaWeb.Models
@inject HttpClient Http
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudText Typo="Typo.h4" Class="mb-6" Color="Color.Primary">Gestión del Menú</MudText>

    @* Formulario rápido para agregar un producto *@
    <MudPaper Elevation="4" Class="pa-4 mb-6 rounded-lg">
        <MudGrid AlignItems="AlignItems.Center">
            <MudItem xs="12" sm="3">
                <MudTextField @bind-Value="newProduct.Name" Label="Nombre (Ej: Empanada JyQ)" Variant="Variant.Outlined"
                              Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" sm="2">
                <MudTextField @bind-Value="newProduct.Price" Label="Precio ($)" Variant="Variant.Outlined"
                              Margin="Margin.Dense" Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.AttachMoney" />
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudSelect @bind-Value="newProduct.Category" Label="Categoría" Variant="Variant.Outlined"
                           Margin="Margin.Dense">
                    <MudSelectItem Value="@("Comida")">Comida</MudSelectItem>
                    <MudSelectItem Value="@("Bebida")">Bebida</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="2">
                <MudTextField @bind-Value="newProduct.Stock" Label="Stock (Bebidas)" Variant="Variant.Outlined"
                              Margin="Margin.Dense" Disabled="@(newProduct.Category == "Comida")" />
            </MudItem>
            <MudItem xs="12" sm="2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="AgregarProducto"
                           Disabled="@(string.IsNullOrEmpty(newProduct.Name) || newProduct.Price <= 0)">
                    AGREGAR
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @* Tabla de productos existentes *@
    <MudTable Items="@products" Dense="true" Hover="true" Elevation="4" Class="rounded-lg">
        <HeaderContent>
            <MudTh>Nombre</MudTh>
            <MudTh>Categoría</MudTh>
            <MudTh>Precio</MudTh>
            <MudTh>Stock</MudTh>
            <MudTh>Estado (Visible en Web)</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd><b>@context.Name</b></MudTd>
            <MudTd>
                <MudChip T="string" Color="@(context.Category == "Bebida" ? Color.Info : Color.Warning)"
                         Size="Size.Small">@context.Category</MudChip>
            </MudTd>
            <MudTd>$ @context.Price</MudTd>
            <MudTd>@(context.Category == "Bebida" ? context.Stock.ToString() : "-")</MudTd>
            <MudTd>
                <MudSwitch Value="@context.IsActive" ValueChanged="@(async (bool val) => await ToggleEstado(context))"
                           Color="Color.Success" Label="@(context.IsActive ? "Activo" : "Pausado")" />
            </MudTd>
        </RowTemplate>
    </MudTable>
</MudContainer>

@code {
    private List<Product> products = new();
    private Product newProduct = new() { Category = "Comida", Stock = 0, IsActive = true };

    protected override async Task OnInitializedAsync()
    {
        await CargarProductos();
    }

    private async Task CargarProductos()
    {
        try
        {
            products = await Http.GetFromJsonAsync<List<Product>>("api/Producto") ?? new();
        }
        catch (Exception)
        {
            Snackbar.Add("Error al cargar menú", Severity.Error);
        }
    }

    private async Task AgregarProducto()
    {
        var response = await Http.PostAsJsonAsync("api/Producto", newProduct);
        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add("Producto agregado al menú", Severity.Success);
            newProduct = new() { Category = "Comida", Stock = 0, IsActive = true }; // Limpiamos formulario
            await CargarProductos(); // Recargamos la tabla
        }
    }

    private async Task ToggleEstado(Product prod)
    {
        // Cambiamos el estado visualmente rápido
        prod.IsActive = !prod.IsActive;
        
        // Avisamos a la API
        var response = await Http.PutAsync($"api/Producto/{prod.Id}/toggle", null);
        
        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add(prod.IsActive ? $"{prod.Name} ahora está a la venta" : $"{prod.Name} pausado", prod.IsActive ?
Severity.Success : Severity.Warning);
        }
        else
        {
            // Si falla, revertimos el botón
            prod.IsActive = !prod.IsActive;
            Snackbar.Add("Hubo un error al cambiar el estado", Severity.Error);
        }
    }
}