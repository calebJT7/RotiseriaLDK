@page "/dashboard"
@using RotiseriaWeb.Models
@inject HttpClient Http

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4 mb-8">
    <MudText Typo="Typo.h4" Class="mb-6" Color="Color.Primary">Resumen de Finanzas y Ventas</MudText>

    <MudGrid>
        @* --- 1. FILA DE TARJETAS PRINCIPALES (4 métricas clave) --- *@
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="4" Class="pa-4 rounded-lg border-l-4" Style="border-left: 6px solid #4caf50;">
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">VENTAS COMIDA</MudText>
                <MudText Typo="Typo.h4"><b>$ @stats.SalesToday</b></MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="4" Class="pa-4 rounded-lg border-l-4" Style="border-left: 6px solid #FF9800;">
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">CAJA DELIVERY</MudText>
                <MudText Typo="Typo.h4"><b>$ @stats.DeliveryRevenue</b></MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">@stats.DeliveryTrips viajes realizados</MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="4" Class="pa-4 rounded-lg border-l-4" Style="border-left: 6px solid #f44336;">
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">DEUDA TOTAL (FIADOS)</MudText>
                <MudText Typo="Typo.h4" Color="Color.Error"><b>$ @stats.TotalDebt</b></MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="4" Class="pa-4 rounded-lg border-l-4" Style="border-left: 6px solid #2196f3;">
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">PEDIDOS DE HOY</MudText>
                <MudText Typo="Typo.h4"><b>@stats.OrdersCount</b></MudText>
            </MudPaper>
        </MudItem>

        @* --- 2. ALERTA DE STOCK --- *@
        <MudItem xs="12" md="12" Class="mt-4">
            <MudCard Elevation="4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Bebidas con poco Stock</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    @if (stats.LowStock != null && stats.LowStock.Any())
                    {
                        <MudGrid>
                            @foreach (var item in stats.LowStock)
                            {
                                <MudItem xs="12" sm="6" md="4">
                                    <div class="d-flex justify-space-between align-center p-2"
                                         style="border: 1px solid #ccc; border-radius: 4px;">
                                        <MudText>@item.Name</MudText>
                                        <MudChip T="string" Color="Color.Warning" Size="Size.Small">Quedan @item.Stock</MudChip>
                                    </div>
                                </MudItem>
                            }
                        </MudGrid>
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Success">Stock de bebidas completo</MudAlert>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        @* --- 3. HISTORIAL MENSUAL (GRÁFICO Y TABLA) --- *@
        <MudItem xs="12" Class="mt-4">
            <MudCard Elevation="4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Ventas por Mes (Último Año)</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudGrid>
                        <MudItem xs="12" md="7">
                            <MudChart ChartType="ChartType.Bar" ChartSeries="@_series" XAxisLabels="@_labels"
                                      Width="100%" Height="300px" />
                        </MudItem>
                        <MudItem xs="12" md="5">
                            <MudTable Items="@monthlyData" Dense="true" Hover="true" Height="300px" FixedHeader="true">
                                <HeaderContent>
                                    <MudTh>Mes</MudTh>
                                    <MudTh>Total Mensual</MudTh>
                                    <MudTh>Pedidos</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd>@context.Label</MudTd>
                                    <MudTd><b>$ @context.Total</b></MudTd>
                                    <MudTd>@context.OrderCount</MudTd>
                                </RowTemplate>
                            </MudTable>
                        </MudItem>
                    </MudGrid>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private DashboardDTO stats = new();
    private List<MonthlyReportDTO> monthlyData = new();
    private List<ChartSeries<double>> _series = new();
    private string[] _labels = { };
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // 1. Datos del Dashboard diario
            var result = await Http.GetFromJsonAsync<DashboardDTO>("api/Reports/dashboard");
            if (result != null) stats = result;

            // 2. Datos del Historial Mensual
            var history = await Http.GetFromJsonAsync<List<MonthlyReportDTO>>("api/Reports/monthly-history");
            if (history != null)
            {
                monthlyData = history;
                
                // Preparamos el gráfico
                _labels = history.Select(x => x.Label).ToArray();
                _series = new List<ChartSeries<double>>()
                {
                    new ChartSeries<double>() { Name = "Ventas Mensuales", Data = history.Select(x => (double)x.Total).ToArray() }
                };
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error cargando estadísticas: " + ex.Message);
        }
        finally { loading = false; }
    }

    public class MonthlyReportDTO
    {
        public string Label { get; set; } = "";
        public decimal Total { get; set; }
        public int OrderCount { get; set; }
    }
}