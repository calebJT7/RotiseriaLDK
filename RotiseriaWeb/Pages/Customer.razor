@using RotiseriaWeb.Models
@inject HttpClient Http
@inject ISnackbar Snackbar

<MudText Typo="Typo.h4" Class="mb-4" Color="Color.Primary">Gestión de Clientes</MudText>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OpenDialog">
        Nuevo Cliente
    </MudButton>
    <MudSwitch @bind-Value="onlyDebtors" Label="Ver solo deudores" Color="Color.Error" />
</MudStack>

<MudTable Items="@displayedCustomers" T="RotiseriaWeb.Models.Customer" Hover="true" Loading="@loading">
    <HeaderContent>
        <MudTh>Nombre</MudTh>
        <MudTh>Teléfono</MudTh>
        <MudTh>Saldo</MudTh>
        <MudTh>Acciones</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Nombre">@context.Name</MudTd>
        <MudTd DataLabel="Teléfono">@context.Phone</MudTd>
        <MudTd DataLabel="Saldo" Style="@(context.Balance < 0 ? "color:red; font-weight:bold;" : "")">
            $ @context.Balance
        </MudTd>
        <MudTd DataLabel="Acciones">
            <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Info">Editar</MudButton>
        </MudTd>
    </RowTemplate>
</MudTable>

@code {
    private List<RotiseriaWeb.Models.Customer> customers = new();
    private bool loading = true;
    private bool onlyDebtors = false;

    // Propiedad calculada para el filtro
    private IEnumerable<RotiseriaWeb.Models.Customer> displayedCustomers => onlyDebtors
        ? customers.Where(c => c.Balance < 0)
        : customers;

    protected override async Task OnInitializedAsync()
    {
        await LoadCustomers();
    }

    private async Task LoadCustomers()
    {
        loading = true;
        try
        {
            // Intentamos traer los datos de la API
            var result = await Http.GetFromJsonAsync<List<RotiseriaWeb.Models.Customer>>("api/Customer");
            customers = result ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
            Snackbar.Add("No se pudo conectar con la API", Severity.Error);
        }
        finally
        {
            loading = false;
        }
    }

    private void OpenDialog()
    {
        Snackbar.Add("Formulario en desarrollo...", Severity.Info);
    }
}